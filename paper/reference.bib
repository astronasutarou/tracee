	author = {Kojima, Yuto and Sako, Shigeyuki and Ohsawa, Ryou and Takahashi, Hidenori and Doi, Mamoru and Kobayashi, Naoto and Aoki, Tsutomu and Arima, Noriaki and Arimatsu, Ko and Ichiki, Makoto and Ikeda, Shiro and Inooka, Kota and Ita, Yoshifusa and Kasuga, Toshihiro and Kokubo, Mitsuru and Konishi, Masahiro and Maehara, Hiroyuki and Matsunaga, Noriyuki and Mitsuda, Kazuma and Miyata, Takashi and Mori, Yuki and Morii, Mikio and Morokuma, Tomoki and Motohara, Kentaro and Nakada, Yoshikazu and Okumura, Shin-Ichiro and Sarugaku, Yuki and Sato, Mikiya and Shigeyama, Toshikazu and Soyano, Takao and Tanaka, Masaomi and Tarusawa, Ken'ichi and Tominaga, Nozomu and Totani, Tomonori and Urakawa, Seitaro and Usui, Fumihiko and Watanabe, Junichi and Yamashita, Takuya and Yoshikawa, Makoto},
