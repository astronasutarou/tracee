@article{arakawa_artificial_2020,
	title = {An artificial impact on the asteroid (162173) {Ryugu} formed a crater in the gravity-dominated regime},
	volume = {368},
	issn = {0036-8075},
	url = {http://adsabs.harvard.edu/abs/2020Sci...368...67A},
	doi = {10.1126/science.aaz1701},
	abstract = {The Hayabusa2 spacecraft investigated the small asteroid Ryugu, which 
has a rubble-pile structure. We describe an impact experiment on Ryugu
using Hayabusa2’s Small Carry-on Impactor. The impact produced an
artificial crater with a diameter {\textgreater}10 meters, which has a
semicircular shape, an elevated rim, and a central pit. Images of the
impact and resulting ejecta were recorded by the Deployable CAMera 3 for
{\textgreater}8 minutes, showing the growth of an ejecta curtain (the outer edge
of the ejecta) and deposition of ejecta onto the surface. The ejecta
curtain was asymmetric and heterogeneous and it never fully detached
from the surface. The crater formed in the gravity-dominated regime; in
other words, crater growth was limited by gravity not surface strength.
We discuss implications for Ryugu’s surface age.},
	urldate = {2020-06-26},
	journal = {Science},
	author = {Arakawa, M. and Saiki, T. and Wada, K. and Ogawa, K. and Kadono, T. and Shirai, K. and Sawada, H. and Ishibashi, K. and Honda, R. and Sakatani, N. and Iijima, Y. and Okamoto, C. and Yano, H. and Takagi, Y. and Hayakawa, M. and Michel, P. and Jutzi, M. and Shimaki, Y. and Kimura, S. and Mimasu, Y. and Toda, T. and Imamura, H. and Nakazawa, S. and Hayakawa, H. and Sugita, S. and Morota, T. and Kameda, S. and Tatsumi, E. and Cho, Y. and Yoshioka, K. and Yokota, Y. and Matsuoka, M. and Yamada, M. and Kouyama, T. and Honda, C. and Tsuda, Y. and Watanabe, S. and Yoshikawa, M. and Tanaka, S. and Terui, F. and Kikuchi, S. and Yamaguchi, T. and Ogawa, N. and Ono, G. and Yoshikawa, K. and Takahashi, T. and Takei, Y. and Fujii, A. and Takeuchi, H. and Yamamoto, Y. and Okada, T. and Hirose, C. and Hosoda, S. and Mori, O. and Shimada, T. and Soldini, S. and Tsukizaki, R. and Iwata, T. and Ozaki, M. and Abe, M. and Namiki, N. and Kitazato, K. and Tachibana, S. and Ikeda, H. and Hirata, N. and Hirata, N. and Noguchi, R. and Miura, A.},
	month = apr,
