	pages = {135},
	file = {Holman et al. - 2018 - HelioLinC A Novel Approach to the Minor Planet Li.pdf:/home/ohsawa/.local/share/zotero/storage/CA8RU97L/Holman et al. - 2018 - HelioLinC A Novel Approach to the Minor Planet Li.pdf:application/pdf},
}

