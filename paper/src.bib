	volume = {48},
	url = {https://ui.adsabs.harvard.edu/abs/2016DPS....4812005L},
	abstract = {The Transneptunian Automated Occultation Survey (TAOS II) will aim to detect occultations of stars by small ({\textasciitilde}1 km diameter) objects in the Kuiper Belt and beyond. Such events are very rare (\${\textless}0.001 events per star per year) and short in duration ({\textasciitilde}200 ms), so many stars must be monitored at a high readout cadence. TAOS II will operate three 1.3 meter telescopes at the Observatorio Astronomico Nacional at San Pedro Martir in Baja California, Mexico. With a 2.3 square degree field of view and a high speed camera comprising CMOS imagers, the survey will monitor 10,000 stars simultaneously with all three telescopes at a readout cadence of 20 Hz. Construction of the site began in the fall of 2013, and the survey will begin in the summer of 2017. This poster will provide an update on the status of the survey development and the schedule leading to the beginning of survey operations.},
	urldate = {2021-07-26},
	author = {Lehner, Matthew and Wang, Shiang-Yu and Alcock, Charles and Reyes-Ruiz, Mauricio and Castro, Joel and Chen, Wen Ping and Chu, You-Hua and Cook, Kem H. and Geary, John C. and Huang, Chung-Kai and Kim, Dae-Won and Norton, Timothy and Szentgyorgyi, Andrew and Yen, WeiLing and Zhang, Zhi-Wei and Figueroa, Liliana},
	month = oct,
	year = {2016},
	note = {Conference Name: AAS/Division for Planetary Sciences Meeting Abstracts \#48},
	pages = {120.05},
}

@article{lehner_status_2018,
	title = {Status of the {Transneptunian} {Automated} {Occultation} {Survey} ({TAOS} {II})},
	volume = {10700},
	url = {https://ui.adsabs.harvard.edu/abs/2018SPIE10700E..4VL},
	doi = {10.1117/12.2309584},
	abstract = {The Transneptunian Automated Occultation Survey (TAOS II) will aim to detect occultations of stars by small ( 1 km diameter) objects in the Kuiper Belt and beyond. Such events are very rare ({\textless} 10-3 events per star per year) and short in duration ( 200 ms), so many stars must be monitored at a high readout cadence in order to detect events. TAOS II will operate three 1.3 meter telescopes at the Observatorio Astronomico Nacional at San Pedro Martir in Baja California, Mexico. With a 2.3 square degree field of view and a high speed camera comprising CMOS imagers, the survey will monitor 10,000 stars simultaneously with all three telescopes at a readout cadence of 20 Hz. Construction of the site began in the fall of 2013, and the survey will begin by the end of 2018. This paper describes the observing system and provides an update on the status of the survey infrastructure.},
	urldate = {2021-07-26},
	author = {Lehner, Matthew J. and Wang, Shiang-Yu and Reyes-Ruíz, Mauricio and Zhang, Zhi-Wei and Figueroa, Liliana and Huang, Chung-Kai and Yen, Wei-Ling and Alcock, Charles and Alvarez Santana, Fernando and Castro-Chacón, Joel and Chen, Wen-Ping and Chu, You-Hua and Cook, Kem H. and Geary, John C. and Hernández, Benjamín. and Karr, Jennifer E. and Kavelaars, J. J. and Norton, Timothy and Szentgyorgyi, Andrew},
